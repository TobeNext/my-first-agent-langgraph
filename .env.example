APP_ENV=development
HOST=0.0.0.0
PORT=8011

MODEL_PROVIDER=mock
MODEL_NAME=mock/interview-runtime
# MODEL_API_KEY=
# MODEL_BASE_URL=
# DeepSeek example:
# MODEL_PROVIDER=deepseek
# MODEL_NAME=deepseek-v4-flash
# MODEL_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=
# MODEL_TIMEOUT_SECONDS=90
# MODEL_MAX_RETRIES=2
# MODEL_TEMPERATURE=0.2

# Evaluation judge model for DeepEval and Ragas:
# EVAL_MODEL_PROVIDER=deepseek
# EVAL_MODEL_NAME=deepseek-chat
# EVAL_MODEL_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=
# EVAL_MODEL_API_KEY=
# EVAL_MODEL_TIMEOUT_SECONDS=90
# EVAL_MODEL_MAX_RETRIES=2
# EVAL_MODEL_TEMPERATURE=0

EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=384
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_SECONDS=0.2
REDIS_SOCKET_TIMEOUT_SECONDS=0.2
MILVUS_ADDRESS=http://localhost:19530
CHECKPOINT_URL=sqlite:///./checkpoints.db
OUTCOME_ROOT=../my-first-agent/Interview outcome
RAG_LOG_ROOT=../my-first-agent/RAG LOG INFO

OTEL_SERVICE_NAME=interview-python-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=1
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=my-first-agent-local
# Informational metadata only; LangSmith tracing is enabled by LANGSMITH_TRACING + key.
LANGSMITH_DATA_MODE=standard
