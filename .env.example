APP_ENV=development
HOST=0.0.0.0
PORT=8011

MODEL_PROVIDER=mock
MODEL_NAME=mock/interview-runtime
# MODEL_API_KEY=
# MODEL_BASE_URL=
# DeepSeek example:
# MODEL_PROVIDER=deepseek
# MODEL_NAME=deepseek-chat
# MODEL_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=
# MODEL_TIMEOUT_SECONDS=20
# MODEL_MAX_RETRIES=2
# MODEL_TEMPERATURE=0.2

EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=384
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_SECONDS=0.2
REDIS_SOCKET_TIMEOUT_SECONDS=0.2
MILVUS_ADDRESS=http://localhost:19530
CHECKPOINT_URL=sqlite:///./checkpoints.db
OUTCOME_ROOT=../my-first-agent/Interview outcome
RAG_LOG_ROOT=../my-first-agent/RAG LOG INFO
